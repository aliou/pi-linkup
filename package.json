{
  "name": "@aliou/pi-linkup",
  "version": "0.11.0",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-linkup"
  },
  "pi": {
    "extensions": [
      "./src/extensions/web-search/index.ts",
      "./src/extensions/web-answer/index.ts",
      "./src/extensions/web-fetch/index.ts",
      "./src/extensions/command-balance/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "video": "https://assets.aliou.me/github/aliou/pi-linkup/demo.mp4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "skills",
    "README.md"
  ],
  "dependencies": {
    "@aliou/pi-utils-ui": "^0.4.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@earendil-works/pi-tui": "0.74.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish",
    "test": "pnpm exec vitest run"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.8.1",
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.11",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@earendil-works/pi-ai": "$@earendil-works/pi-coding-agent",
      "@earendil-works/pi-tui": "$@earendil-works/pi-coding-agent"
    }
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.26.1"
}
